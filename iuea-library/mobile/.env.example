# ── Backend API ───────────────────────────────────────────────────────────────
# Android emulator: use 10.0.2.2 to reach host machine localhost
# iOS simulator / physical device: use your machine's LAN IP or prod URL
API_BASE_URL=http://10.0.2.2:5000/api

# ── Google OAuth (Android/iOS client IDs from console.cloud.google.com) ───────
GOOGLE_CLIENT_ID=your-android-oauth-client-id.apps.googleusercontent.com

# ── Firebase ──────────────────────────────────────────────────────────────────
# These match your google-services.json (Android) / GoogleService-Info.plist (iOS)
FIREBASE_PROJECT_ID=your-project-id
