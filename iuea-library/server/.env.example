# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (MongoDB) ───────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/iuea_library
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/iuea_library
DATABASE_URI=mongodb://localhost:27017/iuea_library

# ── Seed credentials (used by node prisma/seed.js) ───────────────────────────
ADMIN_EMAIL=admin@iuea.ac.ug
ADMIN_PASSWORD=Admin@IUEA2025!

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Google OAuth (Server / Admin SDK client) ──────────────────────────────────
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Koha ILS Integration ──────────────────────────────────────────────────────
# Get from your Koha instance admin → REST API → OAuth2 clients
KOHA_BASE_URL=https://your-koha-instance.example.com
KOHA_CLIENT_ID=koha-rest-client-id
KOHA_CLIENT_SECRET=koha-rest-client-secret
KOHA_USERNAME=api-username
KOHA_PASSWORD=api-password

# ── Gemini AI (Google AI Studio) ──────────────────────────────────────────────
# Get from: aistudio.google.com → Get API key
GEMINI_API_KEY=AIzaSy...

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get from: Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# VAPID key from: Firebase Console → Project settings → Cloud Messaging → Web Push certificates
FIREBASE_VAPID_KEY=BH7Nf...

# ── Cloudflare R2 (book file storage) ────────────────────────────────────────
# Get from: Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=iuea-library-books
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Email (SMTP / Gmail App Password) ────────────────────────────────────────
# Gmail: enable 2FA → myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# ── CORS origins ──────────────────────────────────────────────────────────────
CLIENT_WEB_URL=http://localhost:5173
CLIENT_MOBILE_URL=http://10.0.2.2:5173
