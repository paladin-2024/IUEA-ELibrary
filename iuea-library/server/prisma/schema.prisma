generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URI")
}

// NOTE: This schema is documentation only.
// The app uses a custom Mongoose adapter (src/config/prisma.js).
// Schema changes must be applied to the Mongoose models in src/models/.

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  name                  String
  email                 String    @unique
  passwordHash          String?
  studentId             String?   @unique
  faculty               String?
  role                  String    @default("student")
  preferredLanguages    String[]  @default(["English"])
  avatar                String?
  readingGoal           Int       @default(20)
  fcmToken              String?
  fcmTokenMobile        String?
  fcmTokenWeb           String?
  kohaPatronId          String?
  isActive              Boolean   @default(true)
  passwordResetToken    String?
  passwordResetExpiresAt DateTime?
  notificationPrefs     Json      @default("{}")
  readingPrefs          Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Book {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  kohaId             String?   @unique
  isbn               String?
  title              String
  author             String
  description        String?
  coverUrl           String?
  fileUrl            String?
  fileKey            String?
  archiveId          String?   @unique
  gutenbergId        Int?      @unique
  fileFormat         String?
  category           String
  faculty            String[]  @default([])
  tags               String[]  @default([])
  languages          String[]  @default(["English"])
  publishedYear      Int?
  pageCount          Int?
  rating             Float     @default(0)
  ratingCount        Int       @default(0)
  isActive           Boolean   @default(true)
  lastSyncedFromKoha DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model UserProgress {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  userId              String    @db.ObjectId
  bookId              String    @db.ObjectId
  currentPage         Int       @default(0)
  currentCfi          String?
  percentComplete     Float     @default(0)
  currentChapter      Int       @default(0)
  bookmarks           Int[]     @default([])
  highlights          Json      @default("[]")
  isSaved             Boolean   @default(false)
  isDownloaded        Boolean   @default(false)
  readingLanguage     String    @default("English")
  totalReadingMinutes Int       @default(0)
  isCompleted         Boolean   @default(false)
  lastReadAt          DateTime?
  lastDevice          String    @default("web")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model ChatSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  bookId    String   @db.ObjectId
  messages  Json     @default("[]")
  language  String   @default("English")
  model     String   @default("gemini-1.5-flash")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
}

model Podcast {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  hostName        String?
  coverUrl        String?
  rssUrl          String    @unique
  category        String?
  language        String    @default("English")
  subscriberCount Int       @default(0)
  playCount       Int       @default(0)
  subscribers     String[]  @default([])
  episodes        Json      @default("[]")
  lastFetched     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Collection {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  name      String
  bookIds   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model AudioCache {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  bookId          String?   @db.ObjectId
  textHash        String?
  chapterIndex    Int?
  language        String
  voiceLang       String?
  audioUrl        String?
  durationSeconds Int?
  generatedAt     DateTime  @default(now())
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([bookId, chapterIndex, language, voiceLang])
  @@index([textHash])
  @@index([expiresAt])
}
