generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URI")
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String?
  studentId          String?  @unique
  faculty            String?
  role               String   @default("student")
  preferredLanguages String[] @default(["English"])
  avatar             String?
  readingGoal        Int      @default(20)
  fcmToken                String?
  fcmTokenMobile          String?
  fcmTokenWeb             String?
  kohaPatronId            String?
  isActive                Boolean  @default(true)
  passwordResetToken      String?
  passwordResetExpiresAt  DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  progresses        UserProgress[]
  chatSessions      ChatSession[]
}

model Book {
  id                 String    @id @default(cuid())
  kohaId             String?   @unique
  isbn               String?
  title              String
  author             String
  description        String?
  coverUrl           String?
  fileUrl            String?
  fileKey            String?
  archiveId          String?   @unique
  gutenbergId        Int?      @unique
  fileFormat         String?
  category           String
  faculty            String[]  @default([])
  tags               String[]  @default([])
  languages          String[]  @default(["English"])
  publishedYear      Int?
  pageCount          Int?
  rating             Float     @default(0)
  ratingCount        Int       @default(0)
  isActive           Boolean   @default(true)
  lastSyncedFromKoha DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  progresses   UserProgress[]
  chatSessions ChatSession[]
  audioCache   AudioCache[]
}

model UserProgress {
  id                  String    @id @default(cuid())
  userId              String
  bookId              String
  currentPage         Int       @default(0)
  currentCfi          String?
  percentComplete     Float     @default(0)
  currentChapter      Int       @default(0)
  bookmarks           Int[]     @default([])
  highlights          Json      @default("[]")
  isSaved             Boolean   @default(false)
  isDownloaded        Boolean   @default(false)
  readingLanguage     String    @default("English")
  totalReadingMinutes Int       @default(0)
  isCompleted         Boolean   @default(false)
  lastReadAt          DateTime?
  lastDevice          String    @default("web")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  messages  Json     @default("[]")
  language  String   @default("English")
  model     String   @default("gemini-1.5-flash")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, bookId])
}

model Podcast {
  id              String    @id @default(cuid())
  title           String
  description     String?
  hostName        String?
  coverUrl        String?
  rssUrl          String    @unique
  category        String?
  language        String    @default("English")
  subscriberCount Int       @default(0)
  episodes        Json      @default("[]")
  lastFetched     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscribers PodcastSubscriber[]
}

model PodcastSubscriber {
  podcastId String
  userId    String

  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@id([podcastId, userId])
}

model Collection {
  id        String   @id @default(cuid())
  userId    String
  name      String
  bookIds   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AudioCache {
  id              String    @id @default(cuid())
  bookId          String?
  textHash        String?
  chapterIndex    Int?
  language        String
  voiceLang       String?
  voice           String?
  fileKey         String?
  fileUrl         String?
  audioUrl        String?
  durationSeconds Int?
  generatedAt     DateTime  @default(now())
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  book Book? @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, chapterIndex, language, voiceLang])
  @@index([textHash])
  @@index([expiresAt])
}
