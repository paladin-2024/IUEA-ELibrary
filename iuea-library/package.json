{
  "name": "iuea-library",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["web", "server"],
  "scripts": {
    "dev:web":    "npm run dev --workspace=web",
    "dev:server": "npm run dev --workspace=server",
    "dev":        "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build:web":    "npm run build --workspace=web",
    "install:all":  "npm install && cd mobile && flutter pub get",
    "dev:mobile":   "cd mobile && flutter run",
    "lint:web":     "npm run lint --workspace=web",
    "test:server":  "npm run test --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
