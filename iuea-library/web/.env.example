# ── Backend API ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api

# ── Google OAuth (Web client ID from console.cloud.google.com) ────────────────
VITE_GOOGLE_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com

# ── Firebase CLIENT config (NOT the Admin SDK key) ───────────────────────────
# Get these from: Firebase Console → Project settings → General → Your apps → Web app
# These are public-safe values — do NOT use the Admin SDK private key here.
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ── FCM VAPID key (Cloud Messaging tab → Web Push certificates) ──────────────
VITE_FIREBASE_VAPID_KEY=BH7Nf...
